# Supabase — proyecto
# URL pública del proyecto Supabase (Project Settings > API).
NEXT_PUBLIC_SUPABASE_URL=

# Clave anónima (pública), segura para exponer en el cliente. RLS la protege.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (privada). Nunca exponer al cliente.
# Uso exclusivo en scripts server-side de administración y validación de RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Claude) — Sesión 4 (RAG). Genera la respuesta final del asistente.
# Privada, solo server-side (services/chat.service.ts). Los embeddings NO usan
# esta key: se generan en local con Transformers.js.
ANTHROPIC_API_KEY=
